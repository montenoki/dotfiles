{
    "custom/battery-threshold": {
        "exec": "~/.config/waybar/scripts/battery-threshold.sh",
        "on-click": "~/.config/waybar/scripts/battery-threshold.sh toggle",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "health": "󰂌",
            "full": "󰂏"
        },
        "interval": 60,
        "signal": 8
    }
}
